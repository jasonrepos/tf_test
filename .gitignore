# Local .terraform directories
.terraform/

# Terraform state files (VERY IMPORTANT — contain secrets)
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude all .tfvars files (may contain secrets)
*.tfvars
*.tfvars.json

# Ignore plan
*.tfplan
*tf.plan

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan output files
*.tfplan

# Ignore lock file if you don't want to commit it (optional)
# Usually you SHOULD commit this for reproducibility
# .terraform.lock.hcl

# Ignore sensitive env files
.env
.env.*

# macOS / Windows junk
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/